# KitaKita environment variables
#
# Copy this file to `.env.local` and fill in real values:
#   cp .env.example .env.local        (macOS/Linux)
#   Copy-Item .env.example .env.local (PowerShell)
#
# IMPORTANT: This is a static-export client app (output: "export"), so every var
# the app reads at runtime MUST be prefixed with NEXT_PUBLIC_ and is shipped to
# the device/browser. Do NOT put secrets you can't expose here. For production,
# proxy privileged calls (e.g. Gemini) through a backend and keep real keys there.

# --- Gemini Live (Primary Engine) ---
# API key for the Gemini multimodal session (geminiService).
NEXT_PUBLIC_GEMINI_API_KEY=
# Vision model used to describe camera frames.
NEXT_PUBLIC_GEMINI_MODEL=gemini-2.5-flash

# --- Smart Community Handoff / WebRTC (webrtcService) ---
# Signaling server the app connects to for volunteer/emergency calls.
NEXT_PUBLIC_SIGNALING_URL=
# Comma-separated ICE servers (STUN/TURN), e.g. stun:stun.l.google.com:19302
NEXT_PUBLIC_ICE_SERVERS=stun:stun.l.google.com:19302

# --- Emergency routing (Hazard Override) ---
# Default emergency contact dialed by the panic flow.
NEXT_PUBLIC_EMERGENCY_CONTACT=
# Local emergency services number (e.g. 911, 112, 119).
NEXT_PUBLIC_EMERGENCY_SERVICES_NUMBER=

# --- Location / maps (Outdoor Mode intersection preload) ---
NEXT_PUBLIC_MAPS_API_KEY=
